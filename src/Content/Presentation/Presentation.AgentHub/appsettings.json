{
  "Auth": {
    "Disabled": true
  },
  "AzureAd": {
    "TenantId": "PLACEHOLDER — set via user-secrets in development",
    "ClientId": "PLACEHOLDER — set via user-secrets in development",
    "Audience": "PLACEHOLDER — api://{apiClientId}"
  },
  "AppConfig": {
    "Infrastructure": {
      "FileSystem": {
        "AllowedBasePaths": [ "../../../../../../.." ]
      }
    },
    "AI": {
      "AgentFramework": {
        "DefaultDeployment": "gpt-4o",
        "ClientType": "AzureOpenAI"
      },
      "Governance": {
        "Enabled": true,
        "PolicyPaths": [ "Policies/default-policy.yaml" ],
        "EnablePromptInjectionDetection": true,
        "EnableMcpSecurity": true,
        "EnableAudit": true,
        "EnableMetrics": true,
        "InjectionBlockThreshold": "High"
      },
      "Permissions": {
        "DefaultBehavior": "Ask",
        "DefaultAutonomyLevel": "Supervised",
        "TierPolicies": {
          "Restricted": {
            "DefaultBehavior": "Ask",
            "ToolOverrides": {
              "query_knowledge_graph": "Allow"
            }
          },
          "Supervised": {
            "DefaultBehavior": "Ask",
            "ToolOverrides": {
              "query_knowledge_graph": "Allow",
              "file_system_read": "Allow"
            }
          },
          "Autonomous": {
            "DefaultBehavior": "Allow"
          }
        }
      },
      "Orchestration": {
        "Subagent": {
          "MaxConcurrentSubagents": 3,
          "DefaultMaxTurnsPerSubagent": 10,
          "MailboxStoragePath": ".agent-sessions/mailbox",
          "MaxDelegationDepth": 3,
          "DelegationStoragePath": ".agent-sessions/delegations",
          "DelegationTimeoutSeconds": 300,
          "MaxConcurrentDelegations": 5,
          "CapabilityMatchWeights": {
            "ToolCoverage": 0.4,
            "TypeAlignment": 0.3,
            "TierHeadroom": 0.3
          }
        }
      },
      "Skills": {
        "BasePath": "skills",
        "AdditionalPaths": []
      },
      "Agents": {
        "BasePath": "agents",
        "AdditionalPaths": []
      },
      "Rag": {
        "Ingestion": {
          "DefaultStrategy": "structure_aware",
          "TargetTokens": 512,
          "OverlapTokens": 64,
          "EnableContextualEnrichment": false,
          "EnableRaptorSummaries": false,
          "MaxRaptorDepth": 3
        },
        "Retrieval": {
          "TopK": 10,
          "RerankTopK": 5,
          "RrfK": 60.0,
          "EnableHybrid": true
        },
        "VectorStore": {
          "Provider": "faiss",
          "Endpoint": "",
          "IndexName": "rag-index",
          "EmbeddingModel": "text-embedding-3-large",
          "EmbeddingDimensions": 3072,
          "ApiKey": ""
        },
        "GraphRag": {
          "Enabled": false,
          "GraphProvider": "managed_code",
          "ConnectionString": "",
          "CommunityLevel": 2,
          "MaxEntityExtractionTokens": 4096
        },
        "Reranker": {
          "Strategy": "none",
          "ModelName": ""
        },
        "Crag": {
          "Enabled": false,
          "AcceptThreshold": 0.7,
          "RefineThreshold": 0.4,
          "AllowWebFallback": false
        },
        "QueryTransform": {
          "EnableRagFusion": false,
          "FusionVariantCount": 3,
          "EnableHyde": false,
          "EnableClassification": false
        },
        "ModelTiering": {
          "Enabled": false,
          "DefaultTier": "standard",
          "OperationOverrides": {
            "contextual_enrichment": "economy",
            "raptor_summarization": "economy",
            "crag_evaluation": "standard",
            "query_classification": "economy",
            "rag_fusion": "economy"
          },
          "Tiers": [
            { "Name": "premium", "DeploymentName": "gpt-4o", "MaxTokensPerMinute": 30000 },
            { "Name": "standard", "DeploymentName": "gpt-4o", "MaxTokensPerMinute": 60000 },
            { "Name": "economy", "DeploymentName": "gpt-4o-mini", "MaxTokensPerMinute": 200000 }
          ]
        }
      }
    },
    "AgentHub": {
      "ConversationsPath": "C:/temp/agentic-harness/conversations",
      "DefaultAgentName": "",
      "MaxHistoryMessages": 20,
      "Cors": {
        "AllowedOrigins": [ "http://localhost:5173", "http://localhost:5174" ]
      }
    },
    "Prometheus": {
      "BaseUrl": "http://localhost:9090",
      "TimeoutSeconds": 30,
      "EnableDemoData": false
    },
    "Logging": {
      "PipeName": "AgenticHarnessLogs.AgentHub",
      "LogsBasePath": "logs",
      "EnableStructuredJson": true
    },
    "Observability": {
      "PostgresConnectionString": "Host=localhost;Port=5432;Database=observability;Username=observability;Password=observability",
      "WebTelemetryProjects": [ "Infrastructure.AI.MCPServer", "Presentation.AgentHub" ],
      "Exporters": {
        "Otlp": {
          "Enabled": true,
          "Endpoint": "http://localhost:4317"
        }
      }
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http":  { "Url": "http://*:52000" },
      "Https": { "Url": "https://*:52001" }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
      "System": "Warning"
    }
  }
}
